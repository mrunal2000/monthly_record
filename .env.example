NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Set to "1" to edit without signing in (links/quotes/category frames persist in localStorage;
# collage images use in-memory blob URLs only). For local/dev testing — do NOT enable on public production.

#NEXT_PUBLIC_ALLOW_LOCAL_EDIT_WITHOUT_AUTH=1

# Email sign-in expects a numeric code typed in-app (better on mobile/PWA); Supabase sends the same
# `signInWithOtp` for “magic link” and OTP. Dashboard → Authentication → Email templates → “Magic Link”:
# include {{ .Token }} in the body (see https://supabase.com/docs/guides/auth/auth-email-passwordless#with-otp )
# or recipients only see a clickable link and no digits.

# OpenAI for the draggable “favorites assistant” (server-only; never expose to the client)
# Local: .env.local. On Vercel: Dashboard → your project → Settings → Environment Variables
# (add OPENAI_API_KEY for Production and Preview, then Redeploy).
OPENAI_API_KEY=
# Optional override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Max board images forwarded per reply (URLs must be reachable by OpenAI; default 22, clamp 6–32)
# OPENAI_MAX_VISION_IMAGES=22
